pipeline{
    agent{label 'electronix'}

    stages{
        stage('Creating Database')
        steps{
            sh 'python3 scripts/create_db.py'
        }
    }

     post {
        success {
            echo 'Dtabase creation successful‚úÖ'
        }

        failure {
            echo 'Database failed‚ùå'
        }
    }
}